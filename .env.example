# Anthropic 兼容中转站（非官方也可）：填中转站发的 key 与 base URL
ANTHROPIC_API_KEY=sk-your-key-here
ANTHROPIC_BASE_URL=https://your-relay.example.com/v1
# 可选：中转站上的模型名（不填则用 config.py 的 MODEL）
# ANTHROPIC_MODEL=claude-opus-4-8

NOTION_TOKEN=ntn_your_notion_token
NOTION_OVERVIEW_PARENT_PAGE_ID=your-overview-parent-page-id
NOTION_OPINIONS_DATABASE_ID=your-opinions-database-id
